# ─────────────────────────────────────────────────────────────────
# SupertonicTTS Hindi — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# The .env file is git-ignored. Never commit it.
# ─────────────────────────────────────────────────────────────────

# ── Weights & Biases ─────────────────────────────────────────────
# Get your key at https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# W&B project and team
WANDB_PROJECT=supertonic-hindi-tts
WANDB_ENTITY=your_wandb_username_or_team

# Optional: set a custom run name (defaults to auto-generated)
# WANDB_RUN_NAME=

# Optional: disable wandb (set to "disabled" to turn off completely)
# WANDB_MODE=disabled

# ── Paths (optional overrides) ───────────────────────────────────
# DATA_DIR=./data
# OUTPUT_DIR=./outputs

# ── DGX Spark ────────────────────────────────────────────────────
# CUDA_VISIBLE_DEVICES=0
